# WARNING: Never commit the actual .env file to git.
# For Hugging Face Spaces deployment, set these as Space Secrets at:
# Settings > Variables and secrets
# The .env file is for LOCAL DEVELOPMENT ONLY.

# ── Learnify AI — Environment Variables ──────────────────────
# Copy this file to .env and fill in the values.

# Google Gemini API key (free tier)
GEMINI_API_KEY=

# Groq API key (free tier)
GROQ_API_KEY=

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/learnify

# Ollama local LLM base URL
OLLAMA_BASE_URL=http://localhost:11434

# Path to the FAISS vector index directory
FAISS_INDEX_PATH=./faiss_index

# Set to true for fully offline / privacy-preserving mode
PRIVACY_MODE=false

# Comma-separated list of allowed CORS origins (use * for development only)
# For Hugging Face Spaces, the ALLOWED_ORIGINS secret should be set to the Space URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# JWT Authentication
JWT_SECRET_KEY=yoursecretkeyhere
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
